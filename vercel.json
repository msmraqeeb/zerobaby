{
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}
{
  "rewrites": [
    {
      "source": "/((?!.well-known).*)",
      "destination": "/index.html"
    }
  ]
}